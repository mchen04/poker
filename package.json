{
  "name": "private-poker-home-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"partykit dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "stress": "tsx scripts/poker-stress.ts",
    "modes:gen": "tsx src/lib/gameMode/generate.ts",
    "modes:check": "tsx src/lib/gameMode/generate.ts --check && tsx scripts/verify-mechanics.ts --strict",
    "modes:verify": "tsx scripts/verify-mechanics.ts --strict",
    "predev": "npm run modes:gen",
    "prebuild": "npm run modes:gen && npm run modes:check"
  },
  "dependencies": {
    "nanoid": "^5.0.9",
    "next": "14.2.5",
    "partykit": "^0.0.111",
    "partysocket": "^1.0.2",
    "pokersolver": "^2.1.4",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^2.1.8",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
